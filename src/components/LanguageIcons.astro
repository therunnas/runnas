---
import { Icon } from "astro-icon/components";

interface Language {
  name: string;
  query: string; // valor usado em ?language= no GitHub
  icon: string; // nome do ícone Iconify (set:nome)
}

const languages: Language[] = [
  { name: "Python", query: "Python", icon: "simple-icons:python" },
  { name: "TypeScript", query: "TypeScript", icon: "simple-icons:typescript" },
  { name: "JavaScript", query: "JavaScript", icon: "simple-icons:javascript" },
  { name: "Rust (estudando)", query: "Rust", icon: "simple-icons:rust" },
  { name: "Nix (estudando)", query: "Nix", icon: "simple-icons:nixos" },
];

const repoBase = "https://github.com/therunnas?tab=repositories&language=";
---

<div class="flex flex-wrap items-center gap-3 text-3xl">
  {
    languages.map(({ name, query, icon }) => (
      <a
        href={`${repoBase}${encodeURIComponent(query)}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={name}
        title={name}
        class="hover:opacity-60"
      >
        <Icon name={icon} aria-hidden="true" />
      </a>
    ))
  }
</div>
