---
import {
  SiPython,
  SiTypescript,
  SiJavascript,
  SiRust,
  SiNixos,
} from "react-icons/si";

interface Language {
  name: string;
  query: string; // valor usado em ?language= no GitHub
  icon: typeof SiPython;
}

const languages: Language[] = [
  { name: "Python", query: "Python", icon: SiPython },
  { name: "TypeScript", query: "TypeScript", icon: SiTypescript },
  { name: "JavaScript", query: "JavaScript", icon: SiJavascript },
  { name: "Rust (estudando)", query: "Rust", icon: SiRust },
  { name: "Nix (estudando)", query: "Nix", icon: SiNixos },
];

const repoBase = "https://github.com/therunnas?tab=repositories&language=";
---

<div class="flex flex-wrap items-center gap-3 text-3xl">
  {
    languages.map(({ name, query, icon: Icon }) => (
      <a
        href={`${repoBase}${encodeURIComponent(query)}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={name}
        title={name}
        class="hover:opacity-60"
      >
        <Icon aria-hidden="true" />
      </a>
    ))
  }
</div>
