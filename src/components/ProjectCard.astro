---
interface Props {
  title: string;
  description: string;
  tags: string[];
  sourceUrl?: string;
  liveUrl?: string;
}

const { title, description, tags, sourceUrl, liveUrl } = Astro.props;
---

<div
  class="box-shadow flex w-[280px] min-w-[280px] flex-col border border-black bg-white sm:w-[400px] sm:min-w-[400px]"
>
  <h3 class="border-b border-black p-3 font-bold">{title}</h3>

  <div class="flex flex-wrap gap-1 border-b border-black p-3">
    {
      tags.map((tag) => (
        <span class="border border-black px-1 text-sm">{tag}</span>
      ))
    }
  </div>

  <p class="flex-1 p-3 text-sm">{description}</p>

  {
    (sourceUrl || liveUrl) && (
      <div class="flex justify-end gap-3 border-t border-black p-3 text-sm">
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="underline hover:no-underline"
          >
            Source
          </a>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="underline hover:no-underline"
          >
            View Project
          </a>
        )}
      </div>
    )
  }
</div>
