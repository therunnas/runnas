---
interface Props {
  title: string;
  description: string;
  tags: string[];
  sourceUrl?: string;
  liveUrl?: string;
}

const { title, description, tags, sourceUrl, liveUrl } = Astro.props;
---

<article
  class="rounded-lg border border-neutral-200 p-5 transition-colors hover:border-neutral-400 dark:border-neutral-800 dark:hover:border-neutral-600"
>
  <h3 class="text-base font-semibold">{title}</h3>

  <ul class="mt-2 flex flex-wrap gap-1.5">
    {
      tags.map((tag) => (
        <li class="rounded border border-neutral-300 px-1.5 py-0.5 text-xs text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
          {tag}
        </li>
      ))
    }
  </ul>

  <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">
    {description}
  </p>

  {
    (sourceUrl || liveUrl) && (
      <div class="mt-3 flex gap-4 text-sm">
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-4 hover:no-underline"
          >
            [Source]
          </a>
        )}
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-4 hover:no-underline"
          >
            [View Project]
          </a>
        )}
      </div>
    )
  }
</article>
