---
import { Icon } from "astro-icon/components";

interface SocialLink {
  label: string;
  href: string;
  icon: string; // nome do ícone Iconify (set:nome)
}

// Adicione novas redes aqui — a estrutura já fica pronta.
// (evite contatos que revelem o nome real, ex.: email pessoal)
const links: SocialLink[] = [
  {
    label: "GitHub",
    href: "https://github.com/therunnas",
    icon: "feather:github",
  },
];
---

<div class="flex items-center gap-4 text-2xl">
  {
    links.map(({ label, href, icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        title={label}
        class="hover:opacity-60"
      >
        <Icon name={icon} aria-hidden="true" />
      </a>
    ))
  }
</div>
