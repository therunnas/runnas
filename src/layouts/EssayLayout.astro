---
import Layout from "./Layout.astro";

interface Props {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("pt-BR", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(new Date(frontmatter.date));
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <a
    href="/"
    class="text-sm text-neutral-500 underline underline-offset-4 hover:no-underline dark:text-neutral-400"
  >
    ← voltar
  </a>

  <article class="mt-10">
    <header class="mb-8">
      <h1 class="text-2xl font-semibold">{frontmatter.title}</h1>
      <time
        datetime={frontmatter.date}
        class="mt-1 block text-sm text-neutral-400 dark:text-neutral-600"
      >
        {formattedDate}
      </time>
    </header>

    <div
      class="essay-prose leading-relaxed text-neutral-700 dark:text-neutral-300"
    >
      <slot />
    </div>
  </article>
</Layout>

<style is:global>
  /* Tipografia mínima para o conteúdo dos ensaios (sem plugin externo). */
  .essay-prose > * + * {
    margin-top: 1.25rem;
  }
  .essay-prose h2 {
    margin-top: 2rem;
    font-size: 1.125rem;
    font-weight: 600;
  }
  .essay-prose h3 {
    margin-top: 1.5rem;
    font-weight: 600;
  }
  .essay-prose a {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .essay-prose a:hover {
    text-decoration: none;
  }
  .essay-prose ul,
  .essay-prose ol {
    padding-left: 1.25rem;
    list-style: revert;
  }
  .essay-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
  }
  .essay-prose pre {
    overflow-x: auto;
    border-radius: 0.5rem;
    padding: 1rem;
    font-size: 0.875rem;
  }
  .essay-prose blockquote {
    border-left: 2px solid currentColor;
    padding-left: 1rem;
    opacity: 0.8;
  }
</style>
