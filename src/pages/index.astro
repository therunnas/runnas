---
import Layout from "../layouts/Layout.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
import SocialLinks from "../components/SocialLinks.astro";
import LanguageIcons from "../components/LanguageIcons.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

// Projetos: cada um é um arquivo YAML em src/content/projects/ (schema em
// src/content/config.ts). `order` define a posição no carrossel.
const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Ensaios: solte arquivos .md em src/pages/essays/ com frontmatter `title` e
// `date` (YYYY-MM-DD) usando `layout: ../../layouts/EssayLayout.astro` e eles
// aparecem aqui automaticamente.
// import.meta.glob não quebra quando a pasta está vazia (Astro.glob quebra).
// `!**/_*.md` ignora arquivos prefixados com `_` (ex.: _README.md, rascunhos).
interface PostModule {
  frontmatter: { title: string; date: string };
  url?: string;
}
const essays = Object.values(
  import.meta.glob<PostModule>(["./essays/*.md", "!**/_*.md"], {
    eager: true,
  }),
)
  .map((post) => ({
    title: post.frontmatter.title,
    date: post.frontmatter.date,
    url: post.url ?? "#",
  }))
  .sort((a, b) => (a.date < b.date ? 1 : -1));
---

<Layout title="Runnas">
  <MusicPlayer />

  <!-- Hero + Sobre mim -->
  <div class="intro-about-grid">
    <!-- intro -->
    <div class="box-shadow border border-black bg-white">
      <div class="flex items-center gap-4 p-4">
        <img
          src="/me.webp"
          alt="Foto de Runnas"
          width="80"
          height="80"
          class="h-20 w-20 rounded-full border border-black object-cover"
        />
        <p class="text-xl sm:text-2xl">
          Olá, eu sou o <span class="font-bold">Runnas</span> na internet.
        </p>
      </div>
      <div class="border-t border-black p-4">
        <SocialLinks />
      </div>
    </div>

    <!-- sobre -->
    <div class="box-shadow border border-black bg-black p-4 text-white">
      <h2 class="mb-3 text-lg font-bold">Sobre mim</h2>
      <p class="leading-relaxed">
        Toco a <span class="text-highlight">2K Studios</span>, uma produtora
        audiovisual em Camboriú. É de onde vem meu trabalho e a maior parte do
        meu dia.
      </p>
    </div>
  </div>

  <p class="mt-8 leading-relaxed">
    Programação é hobby genuíno, paralelo ao negócio: gosto de construir,
    aprender tecnologias novas e explorar <span class="text-highlight"
      >automação</span
    >. As coisas aqui nascem da curiosidade, sem pressa e sem pretensão
    comercial.
  </p>

  <!-- Linguagens -->
  <section class="mt-12">
    <p class="mb-4">Linguagens com as quais trabalho</p>
    <LanguageIcons />
  </section>

  <!-- Projetos -->
  <section class="mt-12">
    <h2 class="mb-5 text-xl font-bold sm:text-2xl">Projetos</h2>
    <div class="flex gap-5 overflow-x-auto pb-2">
      {projects.map((project) => <ProjectCard {...project.data} />)}
    </div>
    <a
      href="https://github.com/therunnas?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-block text-sm underline hover:no-underline"
    >
      Ver mais no GitHub
    </a>
  </section>

  <!-- Ensaios -->
  <section class="mt-12">
    <h2 class="mb-5 text-xl font-bold sm:text-2xl">Ensaios</h2>
    {
      essays.length > 0 ? (
        <div class="flex flex-col gap-3">
          {essays.map((essay) => (
            <a
              href={essay.url}
              class="box-shadow flex items-center justify-between gap-4 border border-black bg-white px-3 py-2 text-sm hover:bg-black hover:text-white"
            >
              <span>{essay.title}</span>
              <time datetime={essay.date} class="shrink-0">
                {essay.date}
              </time>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm">Em breve.</p>
      )
    }
  </section>
</Layout>
